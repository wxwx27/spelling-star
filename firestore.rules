rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: students
    // Fields:
    //   - name: string (required)
    //   - lastActive: string (ISO date)
    //   - totalSessions: number
    //   - averageAccuracy: number
    //
    // Collection: sessions
    // Fields:
    //   - studentId: string (required)
    //   - studentName: string
    //   - timestamp: string (ISO date)
    //   - difficulty: string (low|medium|high)
    //   - score: number
    //   - totalWords: number
    //   - accuracy: number
    //   - mistakes: list
    //
    // Collection: wordStats
    // Fields:
    //   - word: string
    //   - mistakeCount: number
    //   - attemptCount: number
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "wxwx27@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['studentId', 'timestamp', 'score', 'totalWords']) &&
             data.studentId is string &&
             data.score is number &&
             data.totalWords is number;
    }

    function isValidWordStat(data) {
      return data.keys().hasAll(['word', 'mistakeCount', 'attemptCount']) &&
             data.word is string &&
             data.mistakeCount is number &&
             data.attemptCount is number;
    }

    // Rules
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidStudent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /wordStats/{wordId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidWordStat(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
